{"ast":null,"code":"export default {\n  name: 'CoSensor',\n  data() {\n    return {\n      coStatus: 'Ładowanie danych...'\n    };\n  },\n  methods: {\n    fetchData() {\n      fetch('/get-data').then(response => response.json()).then(data => {\n        this.coStatus = data.co === 'Wykryty' ? 'Tlenek węgla wykryty!' : 'Brak tlenku węgla.';\n      }).catch(error => {\n        console.error('Błąd:', error);\n        this.coStatus = 'Błąd podczas ładowania danych.';\n      });\n    }\n  },\n  mounted() {\n    this.fetchData();\n    setInterval(this.fetchData, 10000); // Odświeżanie danych co 10 sekund\n  }\n};","map":{"version":3,"names":["name","data","coStatus","methods","fetchData","fetch","then","response","json","co","catch","error","console","mounted","setInterval"],"sources":["/Users/arkadiuszsznura/Desktop/terrasense/frontend/src/components/CoSensor.vue"],"sourcesContent":["<template>\n  <div class=\"co-sensor\">\n    <p><strong>Tlenek węgla:</strong> {{ coStatus }}</p>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'CoSensor',\n  data() {\n    return {\n      coStatus: 'Ładowanie danych...'\n    };\n  },\n  methods: {\n    fetchData() {\n      fetch('/get-data')\n        .then(response => response.json())\n        .then(data => {\n          this.coStatus = data.co === 'Wykryty' ? 'Tlenek węgla wykryty!' : 'Brak tlenku węgla.';\n        })\n        .catch(error => {\n          console.error('Błąd:', error);\n          this.coStatus = 'Błąd podczas ładowania danych.';\n        });\n    }\n  },\n  mounted() {\n    this.fetchData();\n    setInterval(this.fetchData, 10000); // Odświeżanie danych co 10 sekund\n  }\n}\n</script>\n\n<style scoped>\n.co-sensor {\n  text-align: center;\n  margin-top: 20px;\n}\n</style>\n"],"mappings":"AAOA,eAAe;EACbA,IAAI,EAAE,UAAU;EAChBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,QAAQ,EAAE;IACZ,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACPC,SAASA,CAAA,EAAG;MACVC,KAAK,CAAC,WAAW,EACdC,IAAI,CAACC,QAAO,IAAKA,QAAQ,CAACC,IAAI,CAAC,CAAC,EAChCF,IAAI