{"ast":null,"code":"export default {\n  name: 'LightSensor',\n  data() {\n    return {\n      lightState: false\n    };\n  },\n  methods: {\n    fetchLightData() {\n      fetch('/get-data').then(response => response.json()).then(data => {\n        console.log(data);\n        this.lightState = data.light === 'Światło wykryte';\n      }).catch(error => {\n        console.error('Error:', error);\n        this.lightState = false;\n      });\n    }\n  },\n  mounted() {\n    this.fetchLightData();\n    setInterval(this.fetchLightData, 5000);\n  }\n};","map":{"version":3,"names":["name","data","lightState","methods","fetchLightData","fetch","then","response","json","console","log","light","catch","error","mounted","setInterval"],"sources":["/Users/arkadiuszsznura/Desktop/terrasense/frontend/src/components/LightSensor.vue"],"sourcesContent":["<template>\n    <p><strong>Światło:</strong> {{ lightState ? 'Światło wykryte' : 'Brak światła' }}</p>\n</template>\n\n<script>\nexport default {\n  name: 'LightSensor',\n  data() {\n    return {\n      lightState: false\n    };\n  },\n  methods: {\n    fetchLightData() {\n      fetch('/get-data')\n        .then(response => response.json())\n        .then(data => {\n          console.log(data);\n          this.lightState = data.light === 'Światło wykryte';\n        })\n        .catch(error => {\n          console.error('Error:', error);\n          this.lightState = false;\n        });\n    }\n  },\n  mounted() {\n    this.fetchLightData();\n    setInterval(this.fetchLightData, 5000);\n  }\n}\n</script>"],"mappings":"AAKA,eAAe;EACbA,IAAI,EAAE,aAAa;EACnBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,UAAU,EAAE;IACd,CAAC;EACH,CAAC;EACDC,OAAO,EAAE;IACPC,cAAcA,CAAA,EAAG;MACfC,KAAK,CAAC,WAAW,EACdC,IAAI,CAACC,QAAO,IAAKA,QAAQ,CAACC,IAAI,CAAC,CAAC,EAChCF,IAAI,CAACL,IAAG,IAAK;QACZQ,OAAO,CAACC,GAAG,CAACT,IAAI,CAAC;QACjB,IAAI,CAACC,UAAS,GAAID,IAAI,CAACU,KAAI,KAAM,iBAAiB;MACpD,CAAC,EACAC,KAAK,CAACC,KAAI,IAAK;QACdJ,OAAO,CAACI,KAAK,CAAC,QAAQ,EAAEA,KAAK,CAAC;QAC9B,